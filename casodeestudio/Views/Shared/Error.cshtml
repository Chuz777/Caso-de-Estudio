@{
    ViewBag.Title = "Error";
}

<div class="row">
    <div class="col-md-6 col-md-offset-3 text-center" style="padding-top: 60px;">
        <span class="glyphicon glyphicon-exclamation-sign text-danger" style="font-size: 72px;"></span>
        <h2 style="margin-top: 16px;">Ocurrió un error inesperado</h2>
        <p class="text-muted lead">
            No fue posible procesar tu solicitud. Por favor intenta nuevamente o contacta al administrador.
        </p>
        <hr />
        @Html.ActionLink("Volver al inicio", "Index", "Tareas", null, new { @class = "btn btn-primary btn-lg" })
    </div>
</div>